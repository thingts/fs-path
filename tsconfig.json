{
  "include": ["*.ts", "src/**/*", "tests/**/*", "scripts/**/*", "examples/**/*"],
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "$src": ["./src/index.ts"],
      "@tsconfig/fs-path": ["./src/index.ts"]
    },
    "strict": true,
    "strictNullChecks": true,
    "target": "esnext"
  }
}
