{
  "name": "@thingts/fs-path",
  "version": "3.0.1",
  "description": "Type-safe, ergonomic package for working with paths and files in Node.js",
  "keywords": [
    "copy",
    "file",
    "filename",
    "filepath",
    "filesystem",
    "fs",
    "glob",
    "mkdir",
    "node",
    "nodejs",
    "path",
    "posix",
    "rename",
    "tempdir",
    "tempfile",
    "touch",
    "typescript"
  ],
  "homepage": "https://github.com/thingts/fs-path#readme",
  "bugs": {
    "url": "https://github.com/thingts/fs-path/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thingts/fs-path.git"
  },
  "license": "MIT",
  "author": "ronen barzel",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "build:readme": "tsx scripts/embed-examples.ts",
    "docs": "typedoc",
    "lint": "tsc --build --noEmit ; eslint ; knip",
    "test": "vitest run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/picomatch": "^4.0.3",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "typedoc-github-theme": "^0.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@thingts/path": "^3.0.1",
    "tinyglobby": "^0.2.17"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
